# ─────────────────────────────────────────────────────────────
# Proxy de integración Creatio
# Copia este archivo a .env y rellena con los valores reales
# de tu instancia de Creatio (esta demo es agnóstica del tenant)
# ─────────────────────────────────────────────────────────────

# URL base de la instancia Creatio (sin slash al final)
CREATIO_URL=https://tu-instancia.creatio.com

# URL del Identity Service de Creatio para OAuth 2.0
# Patrón típico en Cloud: el subdominio termina en -is.creatio.com
# Si es on-prem o tiene otro layout, ajustar a la URL real.
CREATIO_IDENTITY_URL=https://tu-instancia-is.creatio.com

# Credenciales del OAuth Client
# Crear en Creatio: System Designer → OAuth 2.0 Client Application Management
# Tipo: Client Credentials · Usuario técnico con read sobre la entidad
CREATIO_CLIENT_ID=tu_client_id_aqui
CREATIO_CLIENT_SECRET=tu_client_secret_aqui

# Entidad de Creatio donde está el RUC (Contact, Account, o custom)
CREATIO_ENTITY=Contact

# Nombre técnico del campo RUC en esa entidad
CREATIO_RUC_FIELD=UsrRUC

# Campos a recuperar (lista separada por comas, sin espacios)
CREATIO_SELECT=Name,Email,UsrGender,UsrAge

# Orígenes permitidos por CORS (separados por coma, o '*' para todos)
# En producción restringe al dominio del front:
# ALLOWED_ORIGINS=https://tu-usuario.github.io
ALLOWED_ORIGINS=*

# Puerto en el que escucha el proxy localmente
PORT=3000
